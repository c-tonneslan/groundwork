# Copy to .env.local and fill in.
#
# DATABASE_URL points at a Postgres instance with PostGIS enabled.
# Supabase, Neon, Railway, or a local container all work.
#
# Supabase:
#   1. Create a free project at supabase.com
#   2. Project Settings → Database → Connection string (URI)
#   3. Paste below; replace [YOUR-PASSWORD] with the one shown there.
#
# Local docker:
#   docker run -e POSTGRES_PASSWORD=dev -p 5432:5432 -d postgis/postgis:16-3.4
#   DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

DATABASE_URL=

# Natural-language search (/api/ask). OPTIONAL: a deterministic parser handles
# common questions with no key. Setting a key enables free-form / long-tail
# questions by escalating to the model. Key from https://console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5-20251001).
ANTHROPIC_MODEL=
